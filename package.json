{
  "name": "rondel",
  "version": "0.2.0",
  "description": "Multi-agent orchestration framework built on the Claude CLI",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "rondel": "dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:unit": "vitest run unit.test",
    "test:integration": "vitest run integration.test",
    "test:watch": "vitest unit.test",
    "test:all": "vitest run"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.4"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.28.0",
    "zod": "^4.3.6"
  }
}
