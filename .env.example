# Your Telegram numeric user ID (send /start to @userinfobot to find it).
# The real .env lives at ~/.rondel/.env — `rondel init` creates it.
RONDEL_ALLOWED_USER_ID=123456789

# One bot token per agent, named by the agent's credentialEnvVar in its
# agent.json (convention: {AGENT_NAME}_BOT_TOKEN, from @BotFather).
ASSISTANT_BOT_TOKEN=your-bot-token-here
